# ═══════════════════════════════════════════════════════════════════════════════
# Terraform Variables Example
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to GitHub!
# ═══════════════════════════════════════════════════════════════════════════════

# AWS Region
aws_region = "us-east-1"

# Your SSH key pair name (must exist in AWS)
key_name = "your-key-pair-name"

# Your full name (displayed on web pages)
student_name = "Laila Monzer"

# Optional: Override defaults
# instance_type         = "t2.micro"
# vpc_cidr              = "172.16.0.0/16"
# public_subnet_cidr_1  = "172.16.1.0/24"
# public_subnet_cidr_2  = "172.16.2.0/24"
# private_subnet_cidr_1 = "172.16.10.0/24"
# private_subnet_cidr_2 = "172.16.11.0/24"
